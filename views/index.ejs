<html>

<head>
  <title>Homepage</title>
  <link rel="stylesheet" href="/styles.css">
</head>

<body>
  <ul>
    <% messages.forEach(msg => { %>
      <li><%= msg.user %> <%= msg.text %> <%= msg.added %> 
      <form action="/message" method="post">
        <input type="hidden" name="txt" value="<%= msg.text%>"/>
        <input type="submit" value="Open">
      </form>
      </li>
    <% }) %>
  </ul>
  <a href="/new">Click here to add another</a>
</body>

</html>